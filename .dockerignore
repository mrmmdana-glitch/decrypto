# Exclude everything outside backend/
frontend/
.git/
*.log
*.err.log
railway.json
README.md

# Python cache inside backend
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc

# Secrets — set these as Railway env vars
backend/.env

# Large datasets and model binaries — mount as Railway Volume
backend/data/AddrAddr_edgelist.csv
backend/data/AddrTx_edgelist.csv
backend/data/TxAddr_edgelist.csv
backend/data/wallets_classes.csv
backend/data/wallets_features.csv
backend/models/*.joblib
